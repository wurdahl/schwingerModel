   "source": [
    "#you can make product states using makeState\n",
    "print(\"pipi states\")\n",
    "\n",
    "for I in range(3):\n",
    "    print(I)\n",
    "    for Iz in range(-I,I+1):\n",
    "        print(f\"Iz:{Iz}\", makeState(content=[(MesonOp(\"g5\"),1),(MesonOp(\"g5\"),1)],I=I,I3=Iz,momTotal=0))"
   ]
  },
