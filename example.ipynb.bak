   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "plt.rcParams['font.family'] = 'serif'\n",
    "from tqdm import tqdm\n",
    "\n",
    "from joblib import Parallel, delayed\n",
    "\n",
    "import pickle\n",
    "\n",
    "import schwingerModel as sim\n",
    "\n",
    "from schwingerModel.interpolator import MesonOp, mesonMultiplet, makeState"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "26f48993",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "MesonOp(gamma='g5', DNum=0, momk=0)\n"
     ]
    }
   ],
   "source": [
    "#states are built from mesonOps\n",
    "#they do not contain any flavor info because that is not relevant to the actual traces that are taken\n",
    "g5 = MesonOp(gamma=\"g5\",DNum=0,momk=0)\n",
    "print(g5)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "c1ecf73d",
   "metadata": {},
   "outputs": [],
   "source": [
    "#we can create a state using these mesonOps by first generating the associated MesonMultiplet\n",
    "iso0 = mesonMultiplet(g5,I=0)\n",
    "iso1 = mesonMultiplet(g5,I=1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "1b3c6e2b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Triplet:\n",
      "I_z=-1:  (+1+0j)[u_bar g5 d]\n",
      "I_z=0:  (-0.7071+0j)[d_bar g5 d]  (+0.7071+0j)[u_bar g5 u]\n",
      "I_z=1:  (-1+0j)[d_bar g5 u]\n",
      "Singlet:\n",
      "(-0.7071+0j)[d_bar g5 d]  (-0.7071+0j)[u_bar g5 u]\n"
     ]
    }
   ],
   "source": [
    "#you can access the different Iz components of the mesonMultiplet by indexing them\n",
    "print(\"Triplet:\")\n",
    "for i in range(-1,2):\n",
    "    print(f\"I_z={i}: \", iso1[i])\n",
    "\n",
    "print(\"Singlet:\")\n",
    "print(iso0[0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "084fa47c",
   "metadata": {},
   "outputs": [
    {
