      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "plt.semilogy(np.real(res.conn))\n",
    "plt.xlabel(r\"$\\Delta t$\")\n",
    "plt.ylabel(r\"$\\langle \\bar{O}(t+\\Delta t) O(t)\\rangle$\")\n",
    "plt.title(r\"$\\pi$ Correlation for config. 0\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 60,
   "id": "ef597199",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
       "model_id": "6f9d7910eb19466695a730f939db9bdf",
       "version_major": 2,
       "version_minor": 0
      },
      "text/plain": [
       "Measuring configs:   0%|          | 0/4000 [00:00<?, ?it/s]"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "#instead of doing this by hand for each config, we can use a function to do this automatically\n",
    "#meta.configIndices contains all prepared configuration numbers inside the hdf5 file\n",
    "#we can also add another operator into the basis so that we get a 2x2 correlation matrix at each time step\n",
    "g5 = iso1[0]\n",
    "g5D2 = mesonMultiplet(MesonOp(\"g5\",DNum=2),I=1)[0]\n",
    "ensembleCorrelators = sim.GEVP.measureEnsemble(filePath=path, configIndices=(meta.configIndices)[::20],basis=[g5,g5D2])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 61,
   "id": "f7707465",
   "metadata": {},
   "outputs": [],
   "source": [
    "#now we have 3 choices on how to analyze the data\n",
    "#these three ways all use bootstrapping to analyze the data, \n",
    "#just with different choices for data reduction\n",
    "\n",
    "#The first is no data reduction, so just averaging the 2x2 matrices at each time\n",
    "bootstrappedCorrels = sim.GEVP.bootstrapEnsemble(ensembleCorrelators,progress=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 73,
   "id": "943e6127",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<matplotlib.legend.Legend at 0x7f6f01337390>"
      ]
     },
     "execution_count": 73,
     "metadata": {},
     "output_type": "execute_result"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1050x750 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "central, err, _ = bootstrappedCorrels\n",
    "n, T = central.shape[0], central.shape[-1]\n",
    "ts = np.arange(T)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 5),dpi=150)\n",
    "for a in range(n):\n",
    "    for b in range(n):                      # C is symmetric on average: plot upper triangle\n",
    "        ax.errorbar(ts + 0.05 * (a * n + b),   # tiny x-offset so points don't overlap\n",
    "                    np.abs(central[a, b]),\n",
    "                    yerr=err[[1, 0], a, b, :],\n",
    "                    fmt=\"o--\", ms=3, capsize=2, label=f\"$C_{{{a}{b}}}$\")\n",
    "\n",
    "ax.set_yscale(\"log\")\n",
    "ax.set_xlabel(\"$t$\")\n",
    "ax.set_ylabel(r\"$|C_{ab}(\\Delta t)|$\")\n",
    "ax.legend()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 74,
   "id": "116f4f75",
   "metadata": {},
   "outputs": [],
   "source": [
    "#the next way we can analyze this data is by using GEVP to reduce the data\n",
    "#The function makeGevpReduce is used to make sure that states are labeled consistently acriss bootstrap draws\n",
    "#it is a wrapper on top of sim.GEVP.gevpReduce\n",
    "\n",
    "gevpTi = 1 # we need to choose a point to set as the zeroth point for GEVP, it is helpful if this is not zero\n",
    "bootstrappedGEVP = sim.GEVP.bootstrapEnsemble(ensembleCorrelators,reduce=sim.GEVP.makeGevpReduce(ti=gevpTi),progress=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 77,
   "id": "dec283bc",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<matplotlib.legend.Legend at 0x7f6f03dbae90>"
      ]
     },
     "execution_count": 77,
     "metadata": {},
     "output_type": "execute_result"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 700x500 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "central, err, _ = bootstrappedGEVP\n",
    "nT, nStates = central.shape\n",
    "ts = gevpTi + np.arange(nT)          # curve index k  <->  physical time t = ti + k\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 5))\n",
    "for s in range(nStates):\n",
    "    ax.errorbar(ts + 0.05 * s, central[:, s],\n",
    "                yerr=err[[1, 0], :, s],          # matplotlib wants (lower, upper)\n",
    "                fmt=\"o--\", ms=3, capsize=2, label=f\"state {s}\")\n",
    "\n",
    "ax.set_yscale(\"log\")\n",
    "ax.set_xlabel(\"$t$\")\n",
    "ax.set_ylabel(r\"$\\lambda_s(t)$\")\n",
    "ax.legend()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 78,
   "id": "ecd050dc",
   "metadata": {},
   "outputs": [],
   "source": [
    "#the third way of reducing the data is by fitting exponentials to extract the massses of these states\n",
    "#this is done inside of bootstrapping in order to get the best error bars and correlation of the extracted masses\n",
    "bootstrappedMasses = sim.GEVP.bootstrapEnsemble(ensembleCorrelators,reduce=sim.GEVP.massReduce(ti=gevpTi,fitT=(2,6),withAmp=True),progress=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 96,
   "id": "9b04d22c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Mass of state 0: 1.115 +/- 0.002\n",
      "Mass of state 1: 2.095 +/- 0.078\n"
     ]
    }
   ],
   "source": [
    "#extracing masses and uncertainty \n",
    "masses = bootstrappedMasses[0][:, 0]\n",
    "massesErr = bootstrappedMasses[1][:, :, 0].mean(axis=0) \n",
    "for i in range(2):\n",
    "    print(f\"Mass of state {i}: {masses[i]:.3f} +/- {massesErr[i]:.3f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 100,
   "id": "64ccd03d",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "(1e-08, 2)"
      ]
     },
     "execution_count": 100,
     "metadata": {},
     "output_type": "execute_result"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 700x500 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "#we can compare these masses we found with the plot\n",
    "central, err, _ = bootstrappedGEVP\n",
    "nT, nStates = central.shape\n",
    "ts = gevpTi + np.arange(nT)          # curve index k  <->  physical time t = ti + k\n",
    "\n",
    "fitT = (2, 6)                        # match the massReduce window\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 5))\n",
    "for s in range(nStates):\n",
    "    pts = ax.errorbar(ts + 0.05 * s, central[:, s],\n",
    "                      yerr=err[[1, 0], :, s],\n",
    "                      fmt=\"o\", ms=3, capsize=2, label=f\"state {s}\")\n",
    "\n",
    "    # fitted exponential: curves live in curve-index units k = t - gevpTi\n",
    "    E, logA = bootstrappedMasses[0][s]\n",
    "    kFit = np.linspace(fitT[0], fitT[1] - 1, 50)\n",
    "    ax.plot(gevpTi + kFit, np.exp(logA - E * kFit),\n",
    "            \"-\", color=pts[0].get_color(),\n",
    "            label=rf\"$E_{s}={E:.3f} \\pm {massesErr[s]:.3f}$\")\n",
    "    # dotted continuation outside the fit window\n",
    "    kAll = np.linspace(0, nT - 1, 100)\n",
    "    ax.plot(gevpTi + kAll, np.exp(logA - E * kAll),\n",
    "            \":\", color=pts[0].get_color(), alpha=0.5)\n",
    "\n",
    "ax.axvspan(gevpTi + fitT[0], gevpTi + fitT[1] - 1, color=\"gray\", alpha=0.1)\n",
    "\n",
    "ax.set_yscale(\"log\")\n",
    "ax.set_xlabel(\"$t$\")\n",
    "ax.set_ylabel(r\"$\\lambda_s(t)$\")\n",
    "ax.legend()\n",
    "ax.set_ylim([1e-8,2])\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fefe13f2",
