      "Iz:0 (+0.4082+0j)[d_bar g5,k=-1 d · d_bar g5,k=+1 d]  (-0.4082+0j)[d_bar g5,k=-1 d · u_bar g5,k=+1 u]  (-0.4082+0j)[d_bar g5,k=+1 d · u_bar g5,k=-1 u]  (-0.4082+0j)[d_bar g5,k=-1 u · u_bar g5,k=+1 d]  (-0.4082+0j)[d_bar g5,k=+1 u · u_bar g5,k=-1 d]  (+0.4082+0j)[u_bar g5,k=-1 u · u_bar g5,k=+1 u]\n",
      "Iz:1 (+0.5+0j)[d_bar g5,k=-1 d · d_bar g5,k=+1 u]  (+0.5+0j)[d_bar g5,k=+1 d · d_bar g5,k=-1 u]  (-0.5+0j)[d_bar g5,k=-1 u · u_bar g5,k=+1 u]  (-0.5+0j)[d_bar g5,k=+1 u · u_bar g5,k=-1 u]\n",
      "Iz:2 (+1+0j)[d_bar g5,k=-1 u · d_bar g5,k=+1 u]\n"
     ]
    }
   ],
   "source": [
    "#you can make product states using makeState\n",
    "print(\"piDpi states\")\n",
    "\n",
    "for I in range(3):\n",
    "    print(I)\n",
    "    for Iz in range(-I,I+1):\n",
    "        print(f\"Iz:{Iz}\", makeState(content=[(MesonOp(\"g5\",momk=1),1),(MesonOp(\"g5\",momk=-1),1)],I=I,I3=Iz,momTotal=0))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "faf41303",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "+0.5+0j  Tr[ snk:g5 --d--> ]  x  Tr[ src:g5~ --d--> ]\n",
      "-0.5+0j  Tr[ snk:g5 --d--> ]  x  Tr[ src:g5~ --u--> ]\n",
      "-0.5+0j  Tr[ snk:g5 --d--> src:g5~ --d--> ]\n",
      "-0.5+0j  Tr[ snk:g5 --u--> ]  x  Tr[ src:g5~ --d--> ]\n",
      "+0.5+0j  Tr[ snk:g5 --u--> ]  x  Tr[ src:g5~ --u--> ]\n",
      "-0.5+0j  Tr[ snk:g5 --u--> src:g5~ --u--> ]\n"
     ]
    }
   ],
   "source": [
    "#This returns the weights of a the applicable ways of connecting all vertecies of the graph\n",
    "table = sim.wick.contract(snkOp=iso1[0],srcOp=iso1[0])\n",
    "#format table is a nice way to visualize the traces that will be done\n",
    "print(sim.wick.formatTable(table))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "688aab77",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "'-1+0j  Tr[ snk:g5 --q--> src:g5~ --q--> ]'"
      ]
     },
     "execution_count": 22,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "#once we have this from, we don't care about flavors anymore because of isospin symmetry\n",
    "table = sim.wick.mergeFlavors(table)   # u,d edges -> one degenerate class \"q\"\n",
    "sim.wick.formatTable(table)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 37,
   "id": "f72695dd",
   "metadata": {},
   "outputs": [],
   "source": [
    "#This loads the meta data about the lattice configs that will be analyzed\n",
    "path = \"./configs/400kSteps_scale_0.5.hdf5\"\n",
    "meta = sim.distillation.readDistillMeta(path)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "id": "2e025fe5",
   "metadata": {},
   "outputs": [],
   "source": [
    "#to do the anakysis manually, you load in the distillation files\n",
    "#they are stored in an hdf5 file\n",
    "#this load function loads the distillation info for one config\n",
    "ws = sim.distillation.DistillWorkspace.load(path,configIndex=0)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 35,
   "id": "7a689830",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "modelObj     SimpleNamespace\n",
      "configIndex  int\n",
      "chemicalPot  int\n",
      "eigVecs      (16, 8, 5) complex128\n",
      "_tau         (16, 16, 5, 2, 5, 2) complex128\n",
      "_elem        keys: [(0, 0), (0, 1), (0, 2), (1, 0), (1, 1), (1, 2), (2, 0), (2, 1), (2, 2)]\n"
     ]
    }
   ],
   "source": [
    "#This is what is inside one of these workspaces\n",
    "for name, val in vars(ws).items():\n",
    "    if isinstance(val, np.ndarray):\n",
    "        print(f\"{name:12s} {val.shape} {val.dtype}\")\n",
    "    elif isinstance(val, dict):\n",
    "        print(f\"{name:12s} keys: {sorted(val)}\")\n",
    "    else:\n",
    "        print(f\"{name:12s} {type(val).__name__}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 38,
   "id": "4285e0c8",
   "metadata": {},
   "outputs": [],
   "source": [
    "#we can now evaluate the trace we found using this workspace\n",
    "res = sim.evaluator.evalTable(ws, table)     # EvalResult(conn, disc)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 49,
   "id": "cfabfeb1",
   "metadata": {},
   "outputs": [
    {
